-- ШАГ 2: ВСПОМОГАТЕЛЬНАЯ ФУНКЦИЯ (Триггер updated_at)
-- -------------------------------------------------------------------------
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = CURRENT_TIMESTAMP;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

