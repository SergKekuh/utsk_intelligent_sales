-- 5.1 Документы (Накладные)
CREATE TABLE documents (
    id BIGINT PRIMARY KEY,
    client_code VARCHAR(50) NOT NULL REFERENCES clients(code) ON DELETE CASCADE,
    invoice_date DATE NOT NULL,
    total_amount DECIMAL(15, 2) DEFAULT 0.00 CHECK (total_amount >= 0),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 5.2 Строки документов (Отгрузки)
CREATE TABLE sales_lines (
    id BIGSERIAL PRIMARY KEY,
    document_id BIGINT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
    product_code VARCHAR(50) NOT NULL REFERENCES products(code) ON DELETE RESTRICT,
    quantity DECIMAL(15, 3) NOT NULL CHECK (quantity > 0),
    amount DECIMAL(15, 2) NOT NULL DEFAULT 0.00 CHECK (amount >= 0),
    recorded_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

