-- 4.1 Номенклатура (Продукция)
CREATE TABLE products (
    code VARCHAR(50) PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    anchor_direction_id INT REFERENCES activity_directions(id) ON DELETE SET NULL,
    is_auto_tagged BOOLEAN DEFAULT FALSE,
    material_grade VARCHAR(50),
    is_new_arrival BOOLEAN DEFAULT FALSE,
    in_stock_balance DECIMAL(15,3) DEFAULT 0.00,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 4.2 Синонимы номенклатуры
CREATE TABLE product_aliases (
    id SERIAL PRIMARY KEY,
    product_code VARCHAR(50) NOT NULL REFERENCES products(code) ON DELETE CASCADE,
    alias_text VARCHAR(255) NOT NULL UNIQUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 4.3 Контрагенты (Главная аналитическая таблица)
CREATE TABLE clients (
    code VARCHAR(50) PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    client_type VARCHAR(50),
    current_status_id INT REFERENCES status_rules(id) ON DELETE SET NULL,
    status_history JSONB DEFAULT '[]'::jsonb,
    last_status_push_to_crm TIMESTAMP,
    first_purchase_date DATE,
    last_purchase_date DATE,
    activity_direction_id INT REFERENCES activity_directions(id) ON DELETE SET NULL,
    direction_confidence DECIMAL(5,2) CHECK (direction_confidence >= 0 AND direction_confidence <= 100),
    is_direction_manual BOOLEAN DEFAULT FALSE,
    requires_survey BOOLEAN DEFAULT FALSE,
    survey_completed_at TIMESTAMP,
    survey_completed_by VARCHAR(100),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE clients IS 'Личное дело: Статусы и направления (Тихая аналитика)';

