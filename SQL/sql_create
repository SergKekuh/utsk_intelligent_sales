-- 6.1 Скоринг товаров (Самообучение ML) с проверками CHECK
CREATE TABLE product_scoring (
    id BIGSERIAL PRIMARY KEY,
    client_code VARCHAR(50) NOT NULL REFERENCES clients(code) ON DELETE CASCADE,
    product_code VARCHAR(50) NOT NULL REFERENCES products(code) ON DELETE CASCADE,
    base_score INT DEFAULT 10 CHECK (base_score >= 0 AND base_score <= 100),
    positive_reinforcement INT DEFAULT 0,
    negative_reinforcement INT DEFAULT 0,
    current_weight INT GENERATED ALWAYS AS (base_score + positive_reinforcement - negative_reinforcement) STORED,
    is_blocked BOOLEAN DEFAULT FALSE,
    blocked_until DATE,
    segment_agro_weight INT DEFAULT 0,
    segment_build_weight INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(client_code, product_code),
    CONSTRAINT chk_current_weight CHECK (base_score + positive_reinforcement - negative_reinforcement >= -100 AND base_score + positive_reinforcement - negative_reinforcement <= 1000)
);

-- 6.2 Жесткие связи товаров (Cross-sells / Фитинги)
CREATE TABLE product_cross_sells (
    id SERIAL PRIMARY KEY,
    main_product_code VARCHAR(50) REFERENCES products(code) ON DELETE CASCADE,
    related_product_code VARCHAR(50) REFERENCES products(code) ON DELETE CASCADE,
    relation_type VARCHAR(50), 
    UNIQUE(main_product_code, related_product_code)
);
COMMENT ON TABLE product_cross_sells IS 'Шпаргалка: Сопутствующие фитинги (Труба -> Фланец/Отвод)';

