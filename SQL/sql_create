-- 6.6 A/B Тестирование (Полигон)
CREATE TABLE ab_tests (
    id SERIAL PRIMARY KEY,
    test_name VARCHAR(100) NOT NULL,
    variant CHAR(1) NOT NULL CHECK (variant IN ('A', 'B', 'C')),
    content JSONB NOT NULL,
    impressions INT DEFAULT 0 CHECK (impressions >= 0),
    clicks INT DEFAULT 0 CHECK (clicks >= 0),
    add_to_cart INT DEFAULT 0 CHECK (add_to_cart >= 0),
    
    ctr DECIMAL(5,2) GENERATED ALWAYS AS (
        CASE WHEN impressions > 0 
        THEN ROUND((clicks::DECIMAL / impressions * 100)::NUMERIC, 2) 
        ELSE 0 END
    ) STORED,
    
    conversion_rate DECIMAL(5,2) GENERATED ALWAYS AS (
        CASE WHEN impressions > 0 
        THEN ROUND((add_to_cart::DECIMAL / impressions * 100)::NUMERIC, 2) 
        ELSE 0 END
    ) STORED,
    
    is_active BOOLEAN DEFAULT TRUE,
    start_date DATE DEFAULT CURRENT_DATE,
    end_date DATE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
COMMENT ON TABLE ab_tests IS 'Полигон: A/B тестирование баннеров и офферов на сайте';

