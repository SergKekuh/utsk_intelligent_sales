{
    "version": 3,
    "configurePresets": [
        {
            "name": "dev-linux",
            "displayName": "Linux Development",
            "description": "Сборка для разработки (Linux/GCC)",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_GUI": "OFF",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "release-linux",
            "displayName": "Linux Release",
            "description": "Сборка для релиза (Linux/GCC)",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build_release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "OFF",
                "BUILD_GUI": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "dev-linux"
        },
        {
            "name": "release",
            "configurePreset": "release-linux"
        }
    ]
}
